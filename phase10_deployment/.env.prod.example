# ==============================================================================
# Production Environment Configuration Template
# Instructions: Copy this file to '.env' in the deployment directory and modify
# the variables to suit your environment before deploying. Keep secret keys private!
# ==============================================================================

# ------------------------------------------------------------------------------
# Domain and SSL/TLS Settings
# ------------------------------------------------------------------------------
# The fully qualified domain name (FQDN) where the system will be accessible.
DOMAIN_NAME=co2.example.com

# Email address used for Let's Encrypt renewal notifications and security alerts.
CERTBOT_EMAIL=admin@example.com

# ------------------------------------------------------------------------------
# InfluxDB Configuration
# ------------------------------------------------------------------------------
# Initialization variables for the first-time setup of InfluxDB.
DOCKER_INFLUXDB_INIT_MODE=setup
DOCKER_INFLUXDB_INIT_USERNAME=admin
DOCKER_INFLUXDB_INIT_PASSWORD=ChangeThisToASecureDBPassword123!
DOCKER_INFLUXDB_INIT_ORG=co2-org
DOCKER_INFLUXDB_INIT_BUCKET=co2-data

# API access token for backend components. Must match what is declared in backend configs.
# Generate a secure random token using: openssl rand -hex 32
INFLUXDB_TOKEN=super-secret-auth-token-replace-with-hex-key

# InfluxDB URL (from the perspective of docker networks it uses the container hostname)
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_ORG=co2-org
INFLUXDB_BUCKET=co2-data

# ------------------------------------------------------------------------------
# MQTT Configuration
# ------------------------------------------------------------------------------
MQTT_BROKER=mosquitto
MQTT_TOPIC=iot/co2/sensor1

# ------------------------------------------------------------------------------
# FastAPI Backend API Configuration
# ------------------------------------------------------------------------------
# Secret key used to sign JWT auth tokens. Must be a secure random hex string.
# Generate using: openssl rand -hex 32
SECRET_KEY=fastapi-jwt-signing-secret-key-change-this-in-production

# ------------------------------------------------------------------------------
# Dashboard UI Configuration
# ------------------------------------------------------------------------------
# Secret key for Flask session cookie encryption. Keep secure!
DASHBOARD_SECRET_KEY=flask-session-cookie-secret-key-change-this-in-production
DASHBOARD_CORS_ORIGINS=*
DASHBOARD_HISTORY_LIMIT=300
DASHBOARD_ELEVATED_PPM=900
DASHBOARD_HIGH_PPM=1200
DASHBOARD_CRITICAL_PPM=1800
